}

install_script() {
    echo -e "${BOLD}Tailbox — Tailscale SOCKS Proxy Container - Installation${NC}"
    echo ""

    # 1. Copy script to ~/.local/bin
    mkdir -p ~/.local/bin
    if [[ "$(realpath "$0")" != "$(realpath ~/.local/bin/tailbox 2>/dev/null || echo '')" ]]; then
        cp "$0" ~/.local/bin/tailbox
        chmod +x ~/.local/bin/tailbox
        echo -e "${GREEN}+${NC} Script copied to ~/.local/bin/tailbox"
    else
        echo -e "${GREEN}+${NC} Script already installed in ~/.local/bin/"
    fi

    # 2. Check PATH
    if echo "$PATH" | grep -q "$HOME/.local/bin"; then
        echo -e "${GREEN}+${NC} ~/.local/bin is in PATH"
    else
        echo -e "${YELLOW}!${NC} ~/.local/bin missing from PATH - add it to your shell config"
    fi

    # 3. Create proxychains config (deferred to after port customization in step 6)

    # 4. Check for proxychains-ng
    if command -v proxychains4 &>/dev/null; then
        echo -e "${GREEN}+${NC} proxychains-ng is installed"
    else
        echo -e "${YELLOW}!${NC} proxychains-ng missing - install with: sudo dnf install proxychains-ng"
    fi

    # 5. Create state directory
    mkdir -p "$STATE_DIR"
    echo -e "${GREEN}+${NC} Created ~/tailscale-container/state/"

    # 6. Exit node setup
    echo ""
    echo -e "${BOLD}Exit node (Tailscale SOCKS proxy target):${NC}"
    echo "  The exit node is a machine on your tailnet running a SOCKS proxy"
    echo "  (e.g. microsocks). Tailbox forwards traffic through it."
    echo ""
    if [[ -t 0 ]]; then
        local inst_exit_node inst_exit_node_port inst_socks_port inst_http_port
        read -r -p "Exit node hostname [tailbox-endpoint]: " inst_exit_node
        inst_exit_node="${inst_exit_node:-tailbox-endpoint}"
        read -r -p "Exit node SOCKS port [1080]: " inst_exit_node_port
        inst_exit_node_port="${inst_exit_node_port:-1080}"
        read -r -p "Local SOCKS5 port [1055]: " inst_socks_port
        inst_socks_port="${inst_socks_port:-1055}"
        read -r -p "Local HTTP proxy port [1056]: " inst_http_port
        inst_http_port="${inst_http_port:-1056}"
        EXIT_NODE="$inst_exit_node"
        EXIT_NODE_PORT="$inst_exit_node_port"
        SOCKS_PORT="$inst_socks_port"
        HTTP_PORT="$inst_http_port"
        echo -e "${GREEN}+${NC} Exit node: ${CYAN}${EXIT_NODE}:${EXIT_NODE_PORT}${NC}"
        echo -e "${GREEN}+${NC} Local ports: SOCKS5=${CYAN}${SOCKS_PORT}${NC} HTTP=${CYAN}${HTTP_PORT}${NC}"
    else
        echo -e "${YELLOW}!${NC} No TTY - using defaults (edit ~/tailscale-container/tailbox.conf later)"
    fi

    # 6b. Create proxychains config (after port customization so port is correct)
    if [[ ! -f ~/.proxychains-tailscale.conf ]]; then
        cat > ~/.proxychains-tailscale.conf <<PCEOF
strict_chain
proxy_dns
tcp_read_time_out 15000
tcp_connect_time_out 8000

[ProxyList]
socks5 127.0.0.1 ${SOCKS_PORT}
PCEOF
        echo -e "${GREEN}+${NC} Created ~/.proxychains-tailscale.conf (port ${SOCKS_PORT})"
    else
        echo -e "${GREEN}+${NC} ~/.proxychains-tailscale.conf already exists"
    fi

    # 7. Shell aliases
    echo ""
    echo -e "${BOLD}Shell aliases:${NC}"
    local shell_name rc_file
    shell_name=$(basename "$SHELL")
    case "$shell_name" in
        zsh)  rc_file="$HOME/.zshrc" ;;
        bash) rc_file="$HOME/.bashrc" ;;
        *)    rc_file="$HOME/.${shell_name}rc" ;;
    esac
    echo -e "  Detected shell: ${CYAN}${shell_name}${NC} (${rc_file})"
    echo ""
    if [[ -t 0 ]]; then
        local inst_ssh_alias inst_proxy_alias inst_add_aliases
        echo -e "  ${BOLD}SSH alias${NC} — route SSH through the Tailscale proxy"
        read -r -p "  Alias name [ssht]: " inst_ssh_alias
        inst_ssh_alias="${inst_ssh_alias:-ssht}"
        echo ""
        echo -e "  ${BOLD}Generic proxy alias${NC} — pipe any command through the proxy"
        echo -e "    e.g. ${CYAN}${inst_ssh_alias%% *} curl https://example.com${NC}"
        read -r -p "  Alias name [tb]: " inst_proxy_alias
        inst_proxy_alias="${inst_proxy_alias:-tb}"
        echo ""
        SSH_ALIAS="$inst_ssh_alias"
        PROXY_ALIAS="$inst_proxy_alias"

        read -r -p "  Add aliases to ${rc_file}? [Y/n] " inst_add_aliases
        inst_add_aliases="${inst_add_aliases:-Y}"
        if [[ "$inst_add_aliases" =~ ^[Yy]$ ]]; then
            local marker_start="# --- tailbox aliases (managed by tailbox install) ---"
            local marker_end="# --- end tailbox aliases ---"
            local alias_block
            alias_block=$(cat <<ALIASEOF
${marker_start}
function ${inst_ssh_alias}() {
    if ! podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^tailbox\$'; then
        echo "${inst_ssh_alias}: tailbox not running. Start with: tailbox" >&2
        return 1
    fi
    TERM=xterm-256color proxychains4 -q -f ~/.proxychains-tailscale.conf ssh "\$@"
}

function ${inst_proxy_alias}() {
    if ! podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^tailbox\$'; then
        echo "${inst_proxy_alias}: tailbox not running. Start with: tailbox" >&2
        return 1
    fi
    proxychains4 -q -f ~/.proxychains-tailscale.conf "\$@"
}
${marker_end}
ALIASEOF
)
            if grep -qF "$marker_start" "$rc_file" 2>/dev/null; then
                local replace_aliases
                read -r -p "  Tailbox aliases already exist in ${rc_file}. Replace? [Y/n] " replace_aliases
                replace_aliases="${replace_aliases:-Y}"
                if [[ "$replace_aliases" =~ ^[Yy]$ ]]; then
                    # Remove old block and append new
                    sed -i "/${marker_start//\//\\/}/,/${marker_end//\//\\/}/d" "$rc_file"
                    printf '\n%s\n' "$alias_block" >> "$rc_file"
                    echo -e "${GREEN}+${NC} Replaced aliases in ${rc_file}"
                else
                    echo -e "${YELLOW}!${NC} Keeping existing aliases"
                fi
            elif grep -qE "^function ${inst_ssh_alias}[[:space:](]" "$rc_file" 2>/dev/null; then
                echo -e "${YELLOW}!${NC} Function '${inst_ssh_alias}' already exists in ${rc_file} (not managed by tailbox)"
                local add_anyway
                read -r -p "  Add tailbox aliases anyway (won't remove existing)? [y/N] " add_anyway
                if [[ "$add_anyway" =~ ^[Yy]$ ]]; then
                    printf '\n%s\n' "$alias_block" >> "$rc_file"
                    echo -e "${GREEN}+${NC} Added aliases to ${rc_file}"
                else
                    echo -e "${YELLOW}!${NC} Skipped — add manually or remove existing function first"
                fi
            else
                printf '\n%s\n' "$alias_block" >> "$rc_file"
                echo -e "${GREEN}+${NC} Added aliases to ${rc_file}"
            fi
        else
            echo -e "${GREEN}+${NC} Skipped shell aliases"
        fi
    else
        echo -e "${YELLOW}!${NC} No TTY - skipping alias setup"
    fi

    # 8. Authentication
    echo ""
    echo -e "${BOLD}Authentication:${NC}"
    echo "  On first start, a login URL will open in your browser."
    echo "  Log in to your Tailscale account to connect this node."
    echo ""
    echo "  Alternative: pre-configure an auth key (advanced)"
    if [[ -t 0 ]]; then
        local authkey_choice
        read -r -p "  Set up an auth key now? [y/N] " authkey_choice
        if [[ "$authkey_choice" =~ ^[Yy]$ ]]; then
            echo "  Create one at: https://login.tailscale.com/admin/settings/keys"
            echo -n "  Paste auth key (hidden): "
            local inst_key
            read -rs inst_key
            echo

            if [[ -z "$inst_key" ]]; then
                echo -e "${RED}No key provided, skipping${NC}"
            else
                (umask 077 && printf '%s' "$inst_key" > "$CONTAINER_DIR/authkey")
                chmod 600 "$CONTAINER_DIR/authkey"
                echo -e "${GREEN}+${NC} Auth key saved to ~/tailscale-container/authkey"
                unset inst_key
            fi
        else
            echo -e "${GREEN}+${NC} Will use interactive login URL on first start"
        fi
    else
        echo -e "${YELLOW}!${NC} No TTY - provide auth key later with: tailbox auth"
    fi

    # 9. Save tailbox.conf with current settings
    if [[ ! -f "$TAILBOX_CONF" ]]; then
        mkdir -p "$CONTAINER_DIR"
        cat > "$TAILBOX_CONF" <<CONFEOF
# Tailbox configuration — edit to customize
# Reload by restarting: tailbox stop && tailbox

SOCKS_PORT="$SOCKS_PORT"
HTTP_PORT="$HTTP_PORT"
EXIT_NODE="$EXIT_NODE"
EXIT_NODE_PORT="$EXIT_NODE_PORT"
UPDATE_CHECK_INTERVAL="$UPDATE_CHECK_INTERVAL"
SSH_ALIAS="$SSH_ALIAS"
PROXY_ALIAS="$PROXY_ALIAS"
CONFEOF
        echo -e "${GREEN}+${NC} Saved ~/tailscale-container/tailbox.conf"
    else
        echo -e "${GREEN}+${NC} ~/tailscale-container/tailbox.conf already exists"
    fi

    # 11. Fetch remote digest and build local image (pinned)
    echo ""
    echo -e "${YELLOW}Fetching and pinning Tailscale image...${NC}"
    local remote
    remote=$(remote_digest)
    if [[ -z "$remote" ]]; then
        echo -e "${RED}x${NC} Could not reach registry. Check network and retry."
        return 1
    fi
    build_local_image "$remote" || return 1
    echo -e "${GREEN}+${NC} Image pinned and built"

    echo ""
    echo -e "${GREEN}Installation complete!${NC}"
    echo ""
    echo "Next steps:"
    echo "  1. Start Tailscale:  tailbox"
    echo "  2. Follow the login URL on first start"
    echo "     Or: tailbox auth  (hidden prompt)"
    echo ""
}

case "${1:-}" in
    ""|start)
        if [[ ! -f "$TAILBOX_CONF" ]]; then
            echo -e "${YELLOW}No configuration found. Running first-time setup...${NC}"
            echo ""
            install_script
            echo ""
            echo -e "${YELLOW}Starting tailbox...${NC}"
        fi
        start
        ;;
    stop)
        stop_ts
        ;;
    status)
        status
        ;;
    update|pull)
        update_image
        ;;
    update-check)
        check_for_updates yes
        ;;
    build)
        ensure_image
        ;;
    logs)
        logs
        ;;
    exec)
        shift
        exec_ts "$@"
        ;;
    auth)
        set_authkey "${2:-}"
        ;;
    kill-switch|ks)
        apply_kill_switch
        ;;
    forward|fwd)
        start_exit_node_forward
        ;;
    install)
        install_script
        ;;
    info|--info|-i)
        show_info
        ;;
    help|--help|-h)
        echo "Tailbox — Tailscale SOCKS Proxy Container"
        echo ""
        echo "Usage: tailbox [command]"
        echo ""
        echo "Commands:"
        echo "  start          - Start Tailscale (default)"
        echo "  stop           - Stop Tailscale"
        echo "  status         - Show status and connected nodes"
        echo "  exec <cmd>     - Run tailscale command in the container"
        echo "  auth [<key>]   - Save auth key (hidden prompt if no arg)"
        echo "  kill-switch    - Enable kill switch (block non-Tailscale traffic)"
        echo "  forward        - Restart exit node forward (socat -> microsocks)"
        echo "  update         - Force update & rebuild image"
        echo "  update-check   - Check for updates and prompt to apply"
        echo "  build          - Rebuild local image from pinned digest"
        echo "  logs           - Show logs"
        echo "  install        - Install script, pin + build image"
        echo "  info           - Show detailed info"
        echo ""
        echo "Environment variables:"
        echo "  TS_AUTHKEY              - Auth key for automatic login"
        echo "  TS_EXTRA_ARGS           - Extra args for 'tailscale up'"
        echo "  UPDATE_CHECK_INTERVAL   - Seconds between update checks (default 86400)"
        echo ""
        echo "Requirements: podman, proxychains-ng (for SSH via proxy)"
        echo ""
        echo "Config:      ~/tailscale-container/tailbox.conf"
        echo "State:       ~/tailscale-container/state/"
        echo "Logs:        tailbox logs"
        echo ""
        echo "Current settings:"
        echo "  SOCKS5 port:    $SOCKS_PORT"
        echo "  HTTP port:      $HTTP_PORT"
        echo "  Exit node:      $EXIT_NODE"
        echo "  Exit node port: $EXIT_NODE_PORT"
        echo "  Rootless:       $ROOTLESS"
        echo "  Auth key:       $(if [[ -f "$CONTAINER_DIR/authkey" ]]; then echo 'configured'; else echo 'not set (interactive URL)'; fi)"
        echo "  SSH alias:      $SSH_ALIAS  (e.g. $SSH_ALIAS user@host)"
        echo "  Proxy alias:    $PROXY_ALIAS  (e.g. $PROXY_ALIAS curl https://example.com)"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'tailbox help' for help."
        exit 1
        ;;
esac
