#!/bin/bash
# Tailbox — Tailscale SOCKS Proxy Container
#
# Requirements: podman (sudo dnf install podman)
#
# Installation:
#   mkdir -p ~/.local/bin
#   cp tailbox ~/.local/bin/
#   chmod +x ~/.local/bin/tailbox
#   tailbox install
#
# Usage: tailbox [start|stop|status|exec|auth|forward|kill-switch|update|update-check|build|install|info|help|logs]
#
# First run requires login via URL or auth key.
# State persists in ~/tailscale-container/state/ - only authenticate once.
#
# Image is pinned to a specific digest for supply-chain safety.
# Updates are checked every 24h and the user is prompted before applying.
#
set -uo pipefail

CONTAINER_NAME="tailbox"
CONTAINER_DIR="$HOME/tailscale-container"
STATE_DIR="$CONTAINER_DIR/state"
DIGEST_FILE="$CONTAINER_DIR/upstream-digest"
LAST_CHECK_FILE="$CONTAINER_DIR/last-update-check"
CONTAINERFILE="$CONTAINER_DIR/Containerfile"

UPSTREAM_REPO="docker.io/tailscale/tailscale"
UPSTREAM_TAG="latest"
LOCAL_IMAGE="tailscale-local:latest"

UPDATE_CHECK_INTERVAL="${UPDATE_CHECK_INTERVAL:-86400}"  # 24h default

# Defaults (overridable via ~/tailscale-container/tailbox.conf)
SOCKS_PORT="1055"                        # Local SOCKS5 (socat -> exit node)
HTTP_PORT="1056"                          # Tailscale HTTP proxy
EXIT_NODE="tailbox-endpoint"           # Tailscale hostname for exit node (microsocks)
EXIT_NODE_PORT="1080"                       # microsocks port on the exit node

SSH_ALIAS="${SSH_ALIAS:-ssht}"
PROXY_ALIAS="${PROXY_ALIAS:-tb}"
ROOTLESS=""  # auto-detect; set to "true" or "false" in tailbox.conf

TAILBOX_CONF="$CONTAINER_DIR/tailbox.conf"
# shellcheck source=/dev/null
[[ -f "$TAILBOX_CONF" ]] && source "$TAILBOX_CONF"

# Auto-detect rootless: use rootless if podman works without sudo
if [[ -z "$ROOTLESS" ]]; then
    if podman info &>/dev/null; then
        ROOTLESS=true
    else
        ROOTLESS=false
    fi
fi

# Set podman command based on rootless mode
if [[ "$ROOTLESS" == true ]]; then
    PM="podman"
else
    PM="sudo podman"
fi

proxychains_config() {
    printf 'strict_chain\nproxy_dns\ntcp_read_time_out 15000\ntcp_connect_time_out 8000\n\n[ProxyList]\nsocks5 127.0.0.1 %s\n' "$SOCKS_PORT"
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ============================================================================
# Alias sync — update shell rc file if alias names changed in config
# ============================================================================

sync_aliases() {
    local shell_name rc_file
    shell_name=$(basename "${SHELL:-bash}")
    case "$shell_name" in
        zsh)  rc_file="$HOME/.zshrc" ;;
        bash) rc_file="$HOME/.bashrc" ;;
        *)    rc_file="$HOME/.${shell_name}rc" ;;
    esac

    local marker_start="# --- tailbox aliases (managed by tailbox install) ---"
    local marker_end="# --- end tailbox aliases ---"

    # Only sync if managed aliases exist in rc file
    grep -qF "$marker_start" "$rc_file" 2>/dev/null || return 0

    # Check if current aliases match config
    local current_ssh current_proxy
    current_ssh=$(sed -n "/${marker_start//\//\\/}/,/${marker_end//\//\\/}/p" "$rc_file" \
        | grep -oP '^function \K[^ (]+' | head -1)
    current_proxy=$(sed -n "/${marker_start//\//\\/}/,/${marker_end//\//\\/}/p" "$rc_file" \
        | grep -oP '^function \K[^ (]+' | tail -1)

    [[ "$current_ssh" == "$SSH_ALIAS" && "$current_proxy" == "$PROXY_ALIAS" ]] && return 0

    # Aliases changed — rebuild block
    local alias_block
    alias_block=$(cat <<ALIASEOF
${marker_start}
function ${SSH_ALIAS}() {
    if ! podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^tailbox\$'; then
        echo "${SSH_ALIAS}: tailbox not running. Start with: tailbox" >&2
        return 1
    fi
    TERM=xterm-256color proxychains4 -q -f ~/.proxychains-tailscale.conf ssh "\$@"
}

function ${PROXY_ALIAS}() {
    if ! podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^tailbox\$'; then
        echo "${PROXY_ALIAS}: tailbox not running. Start with: tailbox" >&2
        return 1
    fi
    proxychains4 -q -f ~/.proxychains-tailscale.conf "\$@"
}
${marker_end}
ALIASEOF
)
    sed -i "/${marker_start//\//\\/}/,/${marker_end//\//\\/}/d" "$rc_file"
    printf '\n%s\n' "$alias_block" >> "$rc_file"
    echo -e "${GREEN}Updated aliases in ${rc_file}:${NC} ${SSH_ALIAS} (ssh), ${PROXY_ALIAS} (proxy)"
}

# ============================================================================
# Image management (pinning + update check + custom build)
# ============================================================================

# Query remote registry for the current upstream digest of repo:tag.
# Prints the digest (sha256:...) or nothing if unreachable.
remote_digest() {
    $PM manifest inspect "${UPSTREAM_REPO}:${UPSTREAM_TAG}" 2>/dev/null \
        | python3 -c "
import sys, json, platform
try:
    d = json.load(sys.stdin)
    if 'manifests' in d:
        arch_map = {'x86_64': 'amd64', 'aarch64': 'arm64', 'armv7l': 'arm'}
        want = arch_map.get(platform.machine(), platform.machine())
        for m in d['manifests']:
            if m.get('platform', {}).get('architecture') == want:
                print(m['digest'])
                break
    elif 'digest' in d:
        print(d['digest'])
except Exception:
    pass
" 2>/dev/null
}

# Print currently pinned upstream digest (or empty)
pinned_digest() {
    [[ -f "$DIGEST_FILE" ]] && cat "$DIGEST_FILE" 2>/dev/null || true
}

# Build local image (upstream pinned by digest + socat layer)
build_local_image() {
    local digest="$1"
    if [[ -z "$digest" ]]; then
        echo -e "${RED}No digest provided for build${NC}" >&2
        return 1
    fi

    mkdir -p "$CONTAINER_DIR"
    cat > "$CONTAINERFILE" <<EOF
# Auto-generated by tailbox - do not edit manually
FROM ${UPSTREAM_REPO}@${digest}
RUN apk add --no-cache socat
EOF

    echo -e "${YELLOW}Building local image (${digest:0:19}...) with socat baked in${NC}"
    if ! $PM build -q -t "$LOCAL_IMAGE" -f "$CONTAINERFILE" "$CONTAINER_DIR" >/dev/null; then
        echo -e "${RED}Image build failed${NC}" >&2
        return 1
    fi

    echo "$digest" > "$DIGEST_FILE"
    date +%s > "$LAST_CHECK_FILE"
    echo -e "${GREEN}Image built and pinned to ${digest}${NC}"
}

# Return 0 if it's time for an update check (>UPDATE_CHECK_INTERVAL since last)
should_check_updates() {
    [[ ! -f "$LAST_CHECK_FILE" ]] && return 0
    local last age
    last=$(cat "$LAST_CHECK_FILE" 2>/dev/null || echo 0)
    age=$(( $(date +%s) - last ))
    [[ $age -gt $UPDATE_CHECK_INTERVAL ]]
}

# Check remote for newer digest, prompt user to apply
check_for_updates() {
    local interactive="${1:-yes}"

    echo -e "${YELLOW}Checking for image updates...${NC}"
    local remote current
    remote=$(remote_digest)
    if [[ -z "$remote" ]]; then
        echo -e "${YELLOW}Could not reach registry (offline?). Using pinned version.${NC}"
        date +%s > "$LAST_CHECK_FILE" 2>/dev/null || true
        return 0
    fi

    current=$(pinned_digest)
    if [[ -z "$current" ]]; then
        echo -e "${YELLOW}No pinned version yet - building initial image...${NC}"
        build_local_image "$remote"
        return $?
    fi

    if [[ "$current" == "$remote" ]]; then
        echo -e "${GREEN}Image is up to date${NC}"
        date +%s > "$LAST_CHECK_FILE"
        return 0
    fi

    echo ""
    echo -e "${YELLOW}Image update available:${NC}"
    echo -e "  Current: ${CYAN}${current}${NC}"
    echo -e "  Latest:  ${CYAN}${remote}${NC}"
    echo ""

    if [[ "$interactive" != "yes" ]] || [[ ! -t 0 ]]; then
        echo -e "${YELLOW}Run 'tailbox update' to apply${NC}"
        date +%s > "$LAST_CHECK_FILE"
        return 0
    fi

    local answer
    read -r -p "Update now? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        build_local_image "$remote"
    else
        echo -e "${YELLOW}Keeping current version${NC}"
        date +%s > "$LAST_CHECK_FILE"
    fi
}

# Ensure local image exists; build if missing
ensure_image() {
    if $PM image exists "$LOCAL_IMAGE" 2>/dev/null; then
        return 0
    fi

    local digest
    digest=$(pinned_digest)
    if [[ -z "$digest" ]]; then
        echo -e "${YELLOW}No pinned image. Fetching remote digest...${NC}"
        digest=$(remote_digest)
        if [[ -z "$digest" ]]; then
            echo -e "${RED}Cannot fetch remote digest and no local image exists${NC}" >&2
            return 1
        fi
    fi
    build_local_image "$digest"
}

# ============================================================================
# Container lifecycle
# ============================================================================

start() {
    # Sync shell aliases if config changed
    sync_aliases

    # Periodic update check (24h cadence, skipped if offline)
    if should_check_updates; then
        check_for_updates yes || true
    fi

    ensure_image || return 1

    # Ensure iptable_filter kernel module is loaded (needed for kill switch, root only)
    [[ "$ROOTLESS" != true ]] && { sudo modprobe iptable_filter 2>/dev/null || true; }

    # Remove any existing container
    $PM rm -f "$CONTAINER_NAME" 2>/dev/null || true

    mkdir -p "$STATE_DIR"

    # Fix ownership if migrating from sudo to rootless
    if [[ "$ROOTLESS" == true ]] && find "$STATE_DIR" -maxdepth 1 ! -user "$(id -u)" -print -quit 2>/dev/null | grep -q .; then
        echo -e "${YELLOW}State dir has root-owned files (from previous sudo mode). Fixing...${NC}"
        if sudo chown -R "$(id -u):$(id -g)" "$STATE_DIR" 2>/dev/null; then
            echo -e "${GREEN}Ownership fixed${NC}"
        else
            echo -e "${RED}Could not fix ownership — run: sudo chown -R \$(id -u):\$(id -g) $STATE_DIR${NC}"
        fi
    fi

    echo ""
    echo -e "${CYAN}"
    cat <<'BANNER'
   ████████╗ █████╗ ██╗██╗     ██████╗  ██████╗ ██╗  ██╗
   ╚══██╔══╝██╔══██╗██║██║     ██╔══██╗██╔═══██╗╚██╗██╔╝
      ██║   ███████║██║██║     ██████╔╝██║   ██║ ╚███╔╝
      ██║   ██╔══██║██║██║     ██╔══██╗██║   ██║ ██╔██╗
      ██║   ██║  ██║██║███████╗██████╔╝╚██████╔╝██╔╝ ██╗
      ╚═╝   ╚═╝  ╚═╝╚═╝╚══════╝╚═════╝  ╚═════╝╚═╝  ╚═╝
BANNER
    echo -e "${NC}"
    echo -e "${YELLOW}  Tailscale SOCKS Proxy Container${NC}"
    echo ""

    # Auth key lookup: env -> file -> interactive URL
    local extra_env=()
    local authkey=""
    if [[ -n "${TS_AUTHKEY:-}" ]]; then
        echo -e "Using auth key from TS_AUTHKEY env..."
        authkey="$TS_AUTHKEY"
    elif [[ -f "$CONTAINER_DIR/authkey" ]]; then
        echo -e "Using auth key from ~/tailscale-container/authkey..."
        authkey=$(cat "$CONTAINER_DIR/authkey")
    fi
    [[ -n "$authkey" ]] && extra_env+=("-e" "TS_AUTHKEY=$authkey")
    unset authkey

    # Extra tailscale up args (e.g. --exit-node, --accept-routes)
    if [[ -n "${TS_EXTRA_ARGS:-}" ]]; then
        extra_env+=("-e" "TS_EXTRA_ARGS=$TS_EXTRA_ARGS")
    fi

    # Helper: run the container with given env args
    _start_container() {
        $PM rm -f "$CONTAINER_NAME" 2>/dev/null || true
        local cap_args=()
        if [[ "$ROOTLESS" != true ]]; then
            cap_args+=(--cap-add=NET_ADMIN --cap-add=NET_RAW --device=/dev/net/tun)
        fi
        $PM run -d \
            --name "$CONTAINER_NAME" \
            "${cap_args[@]}" \
            -v "$STATE_DIR:/var/lib/tailscale:Z" \
            -p "127.0.0.1:${SOCKS_PORT}:1081" \
            -p "127.0.0.1:${HTTP_PORT}:8080" \
            -e TS_STATE_DIR=/var/lib/tailscale \
            -e TS_OUTBOUND_HTTP_PROXY_LISTEN=:8080 \
            -e TS_USERSPACE=$([[ "$ROOTLESS" == true ]] && echo true || echo false) \
            "$@" \
            "$LOCAL_IMAGE" >/dev/null
    }

    if ! _start_container "${extra_env[@]}"; then
        echo -e "${RED}Container failed to start${NC}" >&2
        return 1
    fi

    echo -e "Starting container..."

    # Wait for tailscale to either connect or produce a login URL (up to 15s)
    local connected=false login_url=""
    for _ in $(seq 1 15); do
        if $PM exec "$CONTAINER_NAME" tailscale status &>/dev/null; then
            connected=true
            break
        fi
        login_url=$($PM logs "$CONTAINER_NAME" 2>&1 \
            | grep -o 'https://login.tailscale.com/[^ ]*' | head -1 || true)
        [[ -n "$login_url" ]] && break
        sleep 1
    done

    # Auth key failed? Restart container WITHOUT TS_AUTHKEY to force interactive login
    if [[ "$connected" != true ]] && [[ -z "$login_url" ]]; then
        echo -e "${YELLOW}Auth key may be invalid or expired. Restarting without auth key...${NC}"
        # Rebuild extra_env without TS_AUTHKEY
        local restart_env=()
        [[ -n "${TS_EXTRA_ARGS:-}" ]] && restart_env+=("-e" "TS_EXTRA_ARGS=$TS_EXTRA_ARGS")
        _start_container "${restart_env[@]}" || true

        for _ in $(seq 1 15); do
            login_url=$($PM logs "$CONTAINER_NAME" 2>&1 \
                | grep -o 'https://login.tailscale.com/[^ ]*' | head -1 || true)
            [[ -n "$login_url" ]] && break
            if $PM exec "$CONTAINER_NAME" tailscale status &>/dev/null; then
                connected=true
                break
            fi
            sleep 1
        done
    fi

    # Interactive login flow
    if [[ -n "$login_url" ]] && [[ "$connected" != true ]]; then
        echo ""
        echo -e "${YELLOW}════════════════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}  Authentication required${NC}"
        echo -e "${YELLOW}════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "Opening login URL in browser..."
        echo -e "  ${CYAN}${login_url}${NC}"
        xdg-open "$login_url" 2>/dev/null || echo -e "${YELLOW}Could not open browser — open the URL manually${NC}"
        echo ""
        echo -e "Waiting for login (timeout 120s)..."

        for _ in $(seq 1 60); do
            if $PM exec "$CONTAINER_NAME" tailscale status &>/dev/null; then
                connected=true
                break
            fi
            sleep 2
        done
    fi

    sleep 1

    if [[ "$connected" == true ]] || $PM exec "$CONTAINER_NAME" tailscale status &>/dev/null; then
        [[ "$ROOTLESS" != true ]] && apply_kill_switch
        start_exit_node_forward
        show_connected_banner
    else
        echo ""
        echo -e "${RED}Tailscale did not connect within timeout.${NC}"
        echo -e "Check logs: ${CYAN}tailbox logs${NC}"
        echo -e "First login may take longer."
    fi
}

apply_kill_switch() {
    echo -e "${YELLOW}Applying kill switch...${NC}"

    # Detect Tailscale interface name (tailscale0 or tun0)
    local ts_iface
    ts_iface=$($PM exec "$CONTAINER_NAME" sh -c \
        'ip -o link show | grep -oE "(tailscale0|tun0)" | head -1' 2>/dev/null || true)

    if [[ -z "$ts_iface" ]]; then
        echo -e "${RED}No Tailscale interface found, skipping kill switch${NC}"
        return 1
    fi

    # Use legacy iptables (same backend as Tailscale) - append after Tailscale's own chains
    if $PM exec "$CONTAINER_NAME" sh -c "
        ipt='iptables'

        # Idempotent: check if our kill switch marker rule already exists
        \$ipt -C OUTPUT -o eth0 -j DROP 2>/dev/null && exit 0

        # eth0 OUTPUT - allow only Tailscale's own traffic
        \$ipt -A OUTPUT -o eth0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
        \$ipt -A OUTPUT -o eth0 -p udp --dport 41641 -j ACCEPT  # WireGuard
        \$ipt -A OUTPUT -o eth0 -p udp --dport 3478  -j ACCEPT  # STUN
        \$ipt -A OUTPUT -o eth0 -p tcp --dport 443   -j ACCEPT  # Control plane + DERP
        \$ipt -A OUTPUT -o eth0 -p tcp --dport 80    -j ACCEPT  # DERP probe
        \$ipt -A OUTPUT -o eth0 -p udp --dport 53    -j ACCEPT  # DNS
        \$ipt -A OUTPUT -o eth0 -p tcp --dport 53    -j ACCEPT  # DNS
        \$ipt -A OUTPUT -o eth0 -j DROP

        # eth0 INPUT - allow proxy ports + established
        \$ipt -A INPUT -i eth0 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
        \$ipt -A INPUT -i eth0 -p tcp --dport 1081 -j ACCEPT    # socat (exit node forward)
        \$ipt -A INPUT -i eth0 -p tcp --dport 8080 -j ACCEPT    # HTTP proxy
        \$ipt -A INPUT -i eth0 -j DROP
    "; then
        echo -e "${GREEN}Kill switch active - traffic only via ${ts_iface}${NC}"
    else
        echo -e "${RED}Kill switch could not be applied${NC}"
    fi
}

start_exit_node_forward() {
    # Wait for exit node to become reachable (peer discovery via DERP can take 10-15s)
    # Use TCP probe (tailscale nc) instead of disco ping — ping fails through DERP relays
    # even when TCP connectivity works fine
    local reachable=false
    for _ in $(seq 1 4); do
        if $PM exec "$CONTAINER_NAME" timeout 5 tailscale nc "$EXIT_NODE" "$EXIT_NODE_PORT" </dev/null &>/dev/null; then
            reachable=true
            break
        fi
        sleep 2
    done
    if [[ "$reachable" != true ]]; then
        echo -e "${RED}Could not reach ${EXIT_NODE}:${EXIT_NODE_PORT} via Tailscale - is the node online?${NC}"
        return 1
    fi

    echo -e "${YELLOW}Starting exit node forward (socat+tailscale nc -> ${EXIT_NODE}:${EXIT_NODE_PORT})...${NC}"

    # socat is baked into the local image (no runtime apk add needed)
    $PM exec "$CONTAINER_NAME" sh -c 'pkill -x socat 2>/dev/null' 2>/dev/null || true

    # Start socat: listen on 1081, forward via 'tailscale nc' (works in userspace-networking mode)
    $PM exec -d "$CONTAINER_NAME" \
        socat TCP4-LISTEN:1081,fork,reuseaddr "EXEC:tailscale nc ${EXIT_NODE} ${EXIT_NODE_PORT}" 2>/dev/null || true

    sleep 1
    if $PM exec "$CONTAINER_NAME" sh -c 'pgrep -x socat >/dev/null' 2>/dev/null; then
        echo -e "${GREEN}Exit node forward active: localhost:${SOCKS_PORT} -> ${EXIT_NODE}:${EXIT_NODE_PORT}${NC}"
    else
        echo -e "${RED}socat could not be started${NC}"
    fi
}

show_connected_banner() {
    local ts_ip ts_hostname exit_reachable
    ts_ip=$($PM exec "$CONTAINER_NAME" tailscale ip -4 2>/dev/null || echo "unknown")
    ts_hostname=$($PM exec "$CONTAINER_NAME" tailscale status --self --json 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin).get('Self',{}).get('DNSName','').rstrip('.'))" 2>/dev/null \
        || echo "unknown")

    # Check exit node reachability (TCP probe, not disco ping)
    exit_reachable="no"
    if $PM exec "$CONTAINER_NAME" timeout 3 tailscale nc "$EXIT_NODE" "$EXIT_NODE_PORT" </dev/null &>/dev/null; then
        exit_reachable="yes"
    fi

    echo ""
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  Tailscale Connected${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${BOLD}Tailscale IP:${NC}    $ts_ip"
    echo -e "${BOLD}Hostname:${NC}        $ts_hostname"
    echo -e "${BOLD}Exit node:${NC}       ${EXIT_NODE}:${EXIT_NODE_PORT} ($( [[ "$exit_reachable" == yes ]] && echo -e "${GREEN}reachable${NC}" || echo -e "${RED}unreachable${NC}" ))"
    echo -e "${BOLD}SOCKS5 proxy:${NC}    ${CYAN}localhost:${SOCKS_PORT}${NC}"
    echo -e "${BOLD}HTTP proxy:${NC}      ${CYAN}localhost:${HTTP_PORT}${NC}"
    echo ""
    echo -e "${BOLD}Quick start:${NC}"
    echo -e "  ${CYAN}${PROXY_ALIAS} curl https://ifconfig.me${NC}              # any command via proxy"
    echo -e "  ${CYAN}${SSH_ALIAS} user@host${NC}                       # SSH via proxy"
    echo -e "  ${CYAN}tailbox exec status${NC}                    # tailscale status"
    echo -e "  ${CYAN}curl --socks5-hostname localhost:${SOCKS_PORT}${NC}  # Test via proxy"
    echo ""
    echo -e "${BOLD}Exit node setup:${NC}"
    echo -e "  Your exit node (${CYAN}${EXIT_NODE}${NC}) should run a SOCKS proxy on port ${EXIT_NODE_PORT}."
    echo -e "  If the exit node routes through a VPN (e.g. Mullvad), all proxied"
    echo -e "  traffic goes through that VPN. Verify:"
    echo -e "    ${CYAN}${PROXY_ALIAS} curl https://am.i.mullvad.net/connected${NC}"
    echo ""
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "Config: ${CYAN}~/tailscale-container/tailbox.conf${NC}"
    echo -e "Stop:   ${CYAN}tailbox stop${NC}  |  Logs: ${CYAN}tailbox logs${NC}"
    echo ""
}

stop_ts() {
    echo -e "${YELLOW}Stopping Tailscale...${NC}"
    $PM rm -f "$CONTAINER_NAME" 2>/dev/null || true
    echo -e "${GREEN}Stopped${NC}"
}

status() {
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Tailbox Status${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo ""

    # --- Container ---
    local running=false
    if $PM ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
        running=true
        echo -e "  Container:    ${GREEN}running${NC} (${CONTAINER_NAME})"
    else
        echo -e "  Container:    ${RED}stopped${NC} (${CONTAINER_NAME})"
    fi

    # --- Image ---
    local current_digest
    current_digest=$(pinned_digest)
    [[ -n "$current_digest" ]] && echo -e "  Image:        ${CYAN}${current_digest:0:27}...${NC}"

    # --- Networking mode ---
    if $running; then
        local tun_mode
        if $PM exec "$CONTAINER_NAME" ip link show tailscale0 &>/dev/null; then
            tun_mode="kernel"
        else
            tun_mode="userspace"
        fi
        echo -e "  Network:      ${BOLD}${tun_mode}${NC}"
    fi

    # --- Tailscale identity ---
    if $running; then
        local ts_ip ts_hostname
        ts_ip=$($PM exec "$CONTAINER_NAME" tailscale ip -4 2>/dev/null || echo "-")
        ts_hostname=$($PM exec "$CONTAINER_NAME" tailscale status --self --json 2>/dev/null \
            | python3 -c "import sys,json; print(json.load(sys.stdin).get('Self',{}).get('DNSName','').rstrip('.'))" 2>/dev/null \
            || echo "-")
        echo -e "  Tailscale IP: ${BOLD}${ts_ip}${NC}"
        echo -e "  Hostname:     ${ts_hostname}"
    fi

    echo ""

    # --- Proxies ---
    echo -e "${CYAN}  Proxies${NC}"
    local socks_ok=false
    if ss -tlnp 2>/dev/null | grep -q ":${SOCKS_PORT} "; then
        echo -e "  SOCKS5:       ${GREEN}localhost:${SOCKS_PORT}${NC}"
        socks_ok=true
    else
        echo -e "  SOCKS5:       ${RED}port ${SOCKS_PORT} not listening${NC}"
    fi
    if ss -tlnp 2>/dev/null | grep -q ":${HTTP_PORT} "; then
        echo -e "  HTTP proxy:   ${GREEN}localhost:${HTTP_PORT}${NC}"
    else
        echo -e "  HTTP proxy:   ${RED}port ${HTTP_PORT} not listening${NC}"
    fi

    # --- socat forward ---
    if $running; then
        if $PM exec "$CONTAINER_NAME" pgrep -x socat &>/dev/null; then
            echo -e "  Exit fwd:     ${GREEN}active${NC} (socat :1081 -> ${EXIT_NODE}:${EXIT_NODE_PORT})"
        else
            echo -e "  Exit fwd:     ${RED}inactive${NC} (run: tailbox forward)"
        fi
    fi

    # --- VPN test ---
    if $socks_ok; then
        local vpn_result
        vpn_result=$(curl --socks5-hostname "localhost:${SOCKS_PORT}" -m 5 -s https://am.i.mullvad.net/connected 2>/dev/null || echo "")
        if [[ "$vpn_result" == *"connected"* ]]; then
            echo -e "  Mullvad VPN:  ${GREEN}${vpn_result}${NC}"
        elif [[ -n "$vpn_result" ]]; then
            echo -e "  Mullvad VPN:  ${YELLOW}${vpn_result}${NC}"
        else
            echo -e "  Mullvad VPN:  ${RED}timeout${NC}"
        fi
    fi

    echo ""

    # --- Config files ---
    echo -e "${CYAN}  Configuration${NC}"
    echo -e "  Script:       $(realpath "$0" 2>/dev/null || echo "$0")"
    if [[ -f "$TAILBOX_CONF" ]]; then
        echo -e "  Config:       ${GREEN}${TAILBOX_CONF}${NC}"
    else
        echo -e "  Config:       ${YELLOW}none${NC} (using defaults)"
    fi
    echo -e "  State:        ${STATE_DIR}/"
    if [[ -f "$CONTAINER_DIR/authkey" ]]; then
        echo -e "  Auth key:     ${GREEN}${CONTAINER_DIR}/authkey${NC}"
    else
        echo -e "  Auth key:     ${YELLOW}none${NC} (interactive login)"
    fi
    if [[ -f "$HOME/.proxychains-tailscale.conf" ]]; then
        echo -e "  Proxychains:  ${GREEN}~/.proxychains-tailscale.conf${NC}"
    else
        echo -e "  Proxychains:  ${YELLOW}missing${NC} (run: tailbox install)"
    fi
    echo -e "  Aliases:      ${CYAN}${PROXY_ALIAS}${NC} (proxy), ${CYAN}${SSH_ALIAS}${NC} (SSH)"

    echo ""

    # --- Peers ---
    if $running; then
        echo -e "${CYAN}  Tailscale nodes${NC}"
        $PM exec "$CONTAINER_NAME" tailscale status 2>/dev/null | sed 's/^/  /' \
            || echo -e "  ${RED}Could not get status${NC}"
        echo ""
    fi
}

exec_ts() {
    if ! $PM ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
        echo -e "${RED}Container not running. Start with: tailbox${NC}"
        return 1
    fi
    $PM exec "$CONTAINER_NAME" tailscale "$@"
}

logs() {
    $PM logs -f "$CONTAINER_NAME"
}

update_image() {
    echo -e "${YELLOW}Updating Tailscale image...${NC}"
    local remote
    remote=$(remote_digest)
    if [[ -z "$remote" ]]; then
        echo -e "${RED}Could not fetch remote digest${NC}" >&2
        return 1
    fi

    build_local_image "$remote" || return 1
    echo -e "${GREEN}Image updated!${NC}"

    if $PM ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
        echo -e "${YELLOW}Container is running. Restart with: tailbox stop && tailbox${NC}"
    fi
}

set_authkey() {
    local key="${1:-}"
    if [[ -n "$key" ]]; then
        echo -e "${YELLOW}Warning: auth key as argument ends up in shell history.${NC}"
        echo -e "${YELLOW}  Safer: run 'tailbox auth' without argument for hidden prompt.${NC}"
    else
        if [[ ! -t 0 ]]; then
            echo -e "${RED}No TTY - cannot prompt. Use: tailbox auth <key> or TS_AUTHKEY env${NC}" >&2
            return 1
        fi
        echo "Create an auth key at: https://login.tailscale.com/admin/settings/keys"
        echo ""
        echo -n "Paste auth key (hidden, press Enter to confirm): "
        read -rs key
        echo
        [[ -z "$key" ]] && { echo -e "${RED}No auth key provided${NC}" >&2; return 1; }
    fi

    mkdir -p "$CONTAINER_DIR"
    # umask ensures file is created 0600 even during redirect (no race before chmod)
    (umask 077 && printf '%s' "$key" > "$CONTAINER_DIR/authkey")
    chmod 600 "$CONTAINER_DIR/authkey"
    unset key
    echo -e "${GREEN}Auth key saved to ~/tailscale-container/authkey${NC}"
}

